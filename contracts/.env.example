# OPNet Testnet Deployer Keys
#
# EC_PRIVATE_KEY   : 64 hex chars (32 bytes) — secp256k1 / Classical private key
# MLDSA_PRIVATE_KEY: 5120 hex chars (2560 bytes) — Post-Quantum ML-DSA-44 private key

EC_PRIVATE_KEY=your_64_char_ec_private_key_here
MLDSA_PRIVATE_KEY=your_5120_char_mldsa_private_key_here

# Mine deployment: address of the underlying OP_20 token to wrap
UNDERLYING_ADDRESS=

# Staking deployment: address of the xMiner (Mine) contract
XMINER_ADDRESS=

# Factory interaction: bech32 address and Mine pubkey for registerMine
FACTORY_ADDRESS=
MINE_ADDRESS=
