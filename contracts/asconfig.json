{
  "targets": {
    "miner": {
      "outFile": "build/MinerToken.wasm",
      "textFile": "build/MinerToken.wat",
      "use": ["abort=src/miner-token/index/abort"]
    },
    "mine": {
      "outFile": "build/Mine.wasm",
      "textFile": "build/Mine.wat",
      "use": ["abort=src/mine/index/abort"]
    },
    "factory": {
      "outFile": "build/Factory.wasm",
      "textFile": "build/Factory.wat",
      "use": ["abort=src/factory/index/abort"]
    },
    "lava": {
      "outFile": "build/LavaToken.wasm",
      "textFile": "build/LavaToken.wat",
      "use": ["abort=src/lava-token/index/abort"]
    },
    "crystal": {
      "outFile": "build/CrystalToken.wasm",
      "textFile": "build/CrystalToken.wat",
      "use": ["abort=src/crystal-token/index/abort"]
    },
    "storm": {
      "outFile": "build/StormToken.wasm",
      "textFile": "build/StormToken.wat",
      "use": ["abort=src/storm-token/index/abort"]
    }
  },
  "options": {
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "enable": [
      "sign-extension",
      "mutable-globals",
      "nontrapping-f2i",
      "bulk-memory",
      "simd",
      "reference-types",
      "multi-value"
    ],
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start",
    "transform": "@btc-vision/opnet-transform"
  }
}
