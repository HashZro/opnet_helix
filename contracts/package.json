{
  "name": "mines-opnet-contracts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:miner": "asc src/miner-token/index.ts --target miner --measure --uncheckedBehavior never",
    "build:mine": "asc src/mine/index.ts --target mine --measure --uncheckedBehavior never",
    "build:factory": "asc src/factory/index.ts --target factory --measure --uncheckedBehavior never",
    "build": "npm run build:miner && npm run build:mine && npm run build:factory",
    "build:lava": "asc src/lava-token/index.ts --target lava --measure --uncheckedBehavior never",
    "build:crystal": "asc src/crystal-token/index.ts --target crystal --measure --uncheckedBehavior never",
    "build:storm": "asc src/storm-token/index.ts --target storm --measure --uncheckedBehavior never",
    "deploy:miner": "node --experimental-strip-types scripts/deploy-miner.ts",
    "deploy:mine": "node --experimental-strip-types scripts/deploy-mine.ts",
    "deploy:factory": "node --experimental-strip-types scripts/deploy-factory.ts",
    "register:mine": "node --experimental-strip-types scripts/register-mine.ts",
    "deploy:lava": "node --experimental-strip-types scripts/deploy-lava.ts",
    "deploy:crystal": "node --experimental-strip-types scripts/deploy-crystal.ts",
    "deploy:storm": "node --experimental-strip-types scripts/deploy-storm.ts",
    "deploy:mine-lava": "node --experimental-strip-types scripts/deploy-mine-lava.ts",
    "deploy:mine-crystal": "node --experimental-strip-types scripts/deploy-mine-crystal.ts",
    "deploy:mine-storm": "node --experimental-strip-types scripts/deploy-mine-storm.ts",
    "register:mine-lava": "node --experimental-strip-types scripts/register-mine-lava.ts",
    "register:mine-crystal": "node --experimental-strip-types scripts/register-mine-crystal.ts",
    "register:mine-storm": "node --experimental-strip-types scripts/register-mine-storm.ts"
  },
  "dependencies": {
    "@btc-vision/bitcoin": "7.0.0-alpha.11",
    "@btc-vision/btc-runtime": "^1.11.0-rc.10",
    "@btc-vision/transaction": "1.8.0-beta.10",
    "opnet": "1.8.1-beta.13"
  },
  "devDependencies": {
    "@btc-vision/opnet-transform": "1.2.0",
    "assemblyscript": "0.27.36",
    "dotenv": "^16.0.0"
  }
}
